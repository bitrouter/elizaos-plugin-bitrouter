{
  "name": "elizaos-plugin-bitrouter",
  "version": "0.1.0",
  "description": "elizaOS LLM provider plugin that routes model calls through BitRouter.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.0",
    "ai": "^6.0.30"
  },
  "peerDependencies": {
    "@elizaos/core": "^2.0.0"
  },
  "devDependencies": {
    "@elizaos/core": "2.0.0-beta.1",
    "@types/bun": "^1.3.5",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.0.3",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  },
  "scripts": {
    "build": "bun run build.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "BITROUTER_BASE_URL": {
        "type": "string",
        "description": "BitRouter base URL (default http://127.0.0.1:4356).",
        "required": false
      },
      "BITROUTER_API_KEY": {
        "type": "string",
        "description": "BitRouter virtual API key (brvk_...). Optional when BitRouter runs with skip_auth on localhost.",
        "required": false
      }
    }
  }
}
